)\n\u2022 mcqs      \u2192  List[MCQ] returned from API","fontSize":11,"fontFamily":1,"version":3,"versionNonce":1786161035,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":15,"fontStyle":0},{"id":"box-sidebar","type":"rectangle","x":580,"y":195,"width":200,"height":110,"fillStyle":"solid","fillColor":"#e8f5e9","strokeColor":"#388e3c","strokeWidth":1.5,"borderRadius":8,"version":3,"versionNonce":458336933,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-sidebar-label-text","type":"text","x":630.0,"y":176,"width":100,"height":19,"text":"Sidebar","fontSize":11,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":13,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":1,"textColor":"#2e7d32"},{"id":"box-sidebar-text","type":"text","x":590,"y":218,"width":180,"height":75,"text":"1. API Key input\n   (password, persists)\n2. Model selectbox\n3. File uploader\n   (.txt/.pdf/.docx)\n4. Document stats","fontSize":10,"fontFamily":1,"version":3,"versionNonce":1005551147,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"box-main-area","type":"rectangle","x":800,"y":195,"width":220,"height":110,"fillStyle":"solid","fillColor":"#f3e5f5","strokeColor":"#7b1fa2","strokeWidth":1.5,"borderR