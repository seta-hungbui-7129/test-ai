oundElements":[],"link":null,"locked":false},{"id":"box-services-layer-label-text","type":"text","x":585.8,"y":358,"width":428.4,"height":22,"text":"SERVICES LAYER (Pure Python \u2014 No Streamlit imports)","fontSize":14,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":16,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":1,"textColor":"#e65100"},{"id":"box-document-loader","type":"rectangle","x":280,"y":440,"width":320,"height":240,"fillStyle":"solid","fillColor":"#e8f5e9","strokeColor":"#388e3c","strokeWidth":2,"borderRadius":10,"version":3,"versionNonce":1655509189,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-document-loader-label-text","type":"text","x":369.8,"y":419,"width":140.4,"height":21,"text":"document_loader.py","fontSize":13,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":15,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":1,"textColor":"#2e7d32"},{"id":"text-dl-extract","type":"text","x":295,"y":475,"width":290,"height":130,"text":"extract_text(bytes, filename)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nRouting by file extension:\n\n\u251c\u2500 .txt  \u2192  _extract_txt()\n\u2502          decode: UTF-8 \u2192 latin-1 \u2192 cp1252\n\u2502\n\u251c\u2500 .pdf  \u2192  _extract_pdf()\n\u2502          PyPDF2.PdfReader\n\u2502          extract_text() per page\n\u2502\n\u2514\u2500 .docx \u2192  _extract_docx()\n           python-docx.Document\n           collect non-empty paragraphs\n\nRaises ValueError if unsupported.","fontSize":10,"fontFamily":4,"version":3,"versionNonce":922552843,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"box-dl-load","type":"rectangle","x":295,"y":615,"width":290,"height":50,"fillStyle":"solid","fillColor":"#c8e6c9","strokeColor":"#2e7d32","strokeWidth":1,"borderRadius":6,"version":3,"versionNonce":179875877,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-dl-load-label-text","type":"text","x":239.0,"y":597,"width":402.0,"height":18,"text":"load_document(UploadedFile)\nReturns: (text, word_count, char_count)","fontSize":10,"fontFamily":4,"textAlign":"center","verticalAlign":"middle","baseline":12,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":0,"textColor":"#1b5e20"},{"id":"box-mcq-generator","type":"rectangle","x":660,"y":440,"width":680,"height":240,"fillStyle":"solid","fillColor":"#e3f2fd","strokeColor":"#1565c0","strokeWidth":2,"borderRadius":10,"version":3,"versionNonce":512069803,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-mcq-generator-label-text","type":"text","x":937.6,"y":419,"width":124.8,"height":21,"text":"mcq_generator.py","fontSize":13,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":15,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":1,"textColor":"#1565c0"},{"id":"text-mcg-build-prompt","type":"text","x":675,"y":478,"width":310,"height":110,"text":"build_user_prompt()\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n1. Wraps training material\n   inside user message\n\n2. If exclude_questions exists:\n   appends \"DO NOT REPEAT\"\n   block with all previous\n   Q + answer pairs\n\n3. SYSTEM_PROMPT defines\n   JSON schema + rules","fontSize":10,"fontFamily":4,"version":3,"versionNonce":584672133,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"text-mcg-generate","type":"text","x":1000,"y":478,"width":320,"height":110,"text":"generate_mcqs()\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n1. Validate api_key provided\n\n2. Create Anthropic client\n   (base_url: api.anthropic.com)\n\n3. Retry loop (max 3 attempts)\n\n4. For each attempt:\n   \u2192 _call_api()\n   \u2192 Try 3 JSON strategies\n   \u2192 Pydantic validation\n\n5. On all fail \u2192 raise ValueError","fontSize":10,"fontFamily":4,"version":3,"versionNonce":478430027,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"text-mcg-call-api","type":"text","x":675,"y":595,"width":310,"height":70,"text":"_call_api()\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nclient.messages.create(\n  model      = \"claude-haiku-4-5\",\n  max_tokens = 2048,\n  temperature = 0.8,\n  system     = SYSTEM_PROMPT,\n  messages   = [...]\n)\n\nReturns response.content[n].text","fontSize":10,"fontFamily":4,"version":3,"versionNonce":256682725,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"text-mcg-json","type":"text","x":1000,"y":595,"width":320,"height":70,"text":"JSON Extraction Strategies\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n1. raw               \u2192 json.loads()\n2. strip_fences()    \u2192 remove ```json ```\n3. scan_anywhere()   \u2192 find first balanced\n                        { or [ in response\n\nEach strategy: json.loads() \u2192\nMCQList.model_validate()","fontSize":10,"fontFamily":4,"version":3,"versionNonce":1498653163,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"box-models","type":"rectangle","x":280,"y":730,"width":1060,"height":140,"fillStyle":"solid","fillColor":"#fce4ec","strokeColor":"#c62828","strokeWidth":2,"borderRadius":10,"version":3,"versionNonce":1352664645,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-models-label-text","type":"text","x":689.1,"y":709,"width":241.79999999999998,"height":21,"text":"models.py \u2014 Pydantic Validation","fontSize":13,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":15,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":1,"textColor":"#c62828"},{"id":"text-mcq-model","type":"text","x":295,"y":760,"width":320,"height":100,"text":"class MCQ(BaseModel)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\u2022 question:     str  min_length=5\n\u2022 options:       List[str]  4 items\n\u2022 answer:       str  must match\n               one of options\n\u2022 explanation:   str  min_length=10\n\nmodel_post_init():\n  raises ValueError if answer \u2209 options","fontSize":10,"fontFamily":4,"version":3,"versionNonce":234761355,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"text-mcql-model","type":"text","x":640,"y":760,"width":320,"height":100,"text":"class MCQList(BaseModel)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\u2022 questions: List[MCQ]\n              min_length=5\n              max_length=5\n\nIf validation fails:\n  \u2192 Exception caught in retry loop\n  \u2192 Fresh API call made\n  \u2192 Up to 3 total attempts","fontSize":10,"fontFamily":4,"version":3,"versionNonce":2041640357,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"text-system-prompt","type":"text","x":990,"y":760,"width":340,"height":100,"text":"SYSTEM_PROMPT Rules\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\u2022 Return ONLY JSON (no fences)\n\u2022 Exactly 5 questions\n\u2022 4 distinct options each\n\u2022 Different topics \u2014 no overlap\n\u2022 Answer = one option verbatim\n\u2022 Moderate difficulty\n\u2022 If too short \u2192 \"limitation\"\n\u2022 NOTHING else in response","fontSize":10,"fontFamily":4,"version":3,"versionNonce":1849582379,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"box-external-api","type":"rectangle","x":400,"y":920,"width":800,"height":160,"fillStyle":"solid","fillColor":"#ede7f6","strokeColor":"#4527a0","strokeWidth":2,"borderRadius":12,"version":3,"versionNonce":1705834757,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-external-api-label-text","type":"text","x":615.2,"y":898,"width":369.59999999999997,"height":22,"text":"EXTERNAL API \u2014 Anthropic Claude Messages API","fontSize":14,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":16,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":1,"textColor":"#4527a0"},{"id":"text-api-call","type":"text","x":420,"y":960,"width":760,"height":100,"text":"HTTPS POST  \u2192  https://api.anthropic.com/v1/messages\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nRequest:\n  Authorization: Bearer <user API key from sidebar>\n  model:        claude-haiku-4-5 | claude-sonnet-4 | claude-opus-4\n  max_tokens:   2048\n  temperature:  0.8  (variety, not fully random)\n  system:        JSON schema + generation rules\n  messages:      [{\"role\": \"user\", \"content\": <user prompt + do-not-repeat block>}]\n\nResponse:\n  content: [TextBlock(text='<raw JSON>'), ...]\n  If parse/validation fails \u2192 HTTP 200 but Python-side retry (up to 3\u00d7)","fontSize":10,"fontFamily":4,"version":3,"versionNonce":1384039883,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"arrow-upload","type":"arrow","x1":300,"y1":320,"x2":300,"y2":435,"points":[[0,0],[0,115]],"strokeColor":"#e65100","strokeWidth":2,"version":3,"versionNonce":772903013,"isDeleted":false,"fillStyle":"solid","strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"width":0,"height":115,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"arrow-upload-label-text","type":"text","x":250.0,"y":358.5,"width":100,"height":19,"text":"1. Upload file","fontSize":11,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":13,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":0,"textColor":"#e65100"},{"id":"arrow-extract","type":"arrow","x1":440,"y1":520,"x2":655,"y2":520,"points":[[0,0],[215,0]],"strokeColor":"#e65100","strokeWidth":2,"version":3,"versionNonce":567923819,"isDeleted":false,"fillStyle":"solid","strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"width":215,"height":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"arrow-extract-label-text","type":"text","x":497.5,"y":501.0,"width":100,"height":19,"text":"2. Extract text","fontSize":11,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":13,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":0,"textColor":"#e65100"},{"id":"arrow-session-mcq","type":"arrow","x1":720,"y1":680,"x2":720,"y2":720,"points":[[0,0],[0,40]],"strokeColor":"#1565c0","strokeWidth":2,"version":3,"versionNonce":1621900229,"isDeleted":false,"fillStyle":"solid","strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"width":0,"height":40,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"arrow-session-mcq-label-text","type":"text","x":657.3,"y":681.0,"width":125.39999999999999,"height":19,"text":"3. Return List[MCQ]","fontSize":11,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":13,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":0,"textColor":"#1565c0"},{"id":"arrow-to-display","type":"arrow","x1":720,"y1":380,"x2":720,"y2":340,"points":[[0,0],[0,-40]],"strokeColor":"#1565c0","strokeWidth":2,"version":3,"versionNonce":2082082571,"isDeleted":false,"fillStyle":"solid","strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"width":0,"height":40,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"arrow-to-display-label-text","type":"text","x":654.0,"y":341.0,"width":132.0,"height":19,"text":"4. Render HTML cards","fontSize":11,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":13,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":0,"textColor":"#1565c0"},{"id":"arrow-to-api","type":"arrow","x1":720,"y1":680,"x2":720,"y2":915,"points":[[0,0],[0,235]],"strokeColor":"#4527a0","strokeWidth":2,"version":3,"versionNonce":1973058341,"isDeleted":false,"fillStyle":"solid","strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"width":0,"height":235,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"arrow-to-api-label-text","type":"text","x":663.9,"y":778.5,"width":112.2,"height":19,"text":"5. HTTPS API call","fontSize":11,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":13,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":0,"textColor":"#4527a0"},{"id":"arrow-exclude","type":"arrow","x1":720,"y1":370,"x2":600,"y2":530,"points":[[0,0],[-120,160]],"strokeColor":"#f57f17","strokeWidth":1.5,"version":3,"versionNonce":599389611,"isDeleted":false,"fillStyle":"solid","strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"width":120,"height":160,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"arrow-exclude-label-text","type":"text","x":546.0,"y":432.0,"width":228.0,"height":18,"text":"exclude_questions\n(session_state.mcqs)","fontSize":10,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":12,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":0,"textColor":"#f57f17"},{"id":"box-retry-flow","type":"rectangle","x":1500,"y":440,"width":340,"height":300,"fillStyle":"solid","fillColor":"#fff8e1","strokeColor":"#ff8f00","strokeWidth":2,"borderRadius":10,"version":3,"versionNonce":88723077,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-retry-flow-label-text","type":"text","x":1556.9,"y":419,"width":226.2,"height":21,"text":"Deep Dive: Retry + Parse Flow","fontSize":13,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":15,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":1,"textColor":"#e65100"},{"id":"text-retry-flow","type":"text","x":1510,"y":478,"width":320,"height":250,"text":"generate_mcqs()\n\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n\nfor attempt in range(3):\n  raw = _call_api(...)\n\n  for strategy in\n  [raw, strip_fences,\n   scan_anywhere]:\n\n    try:\n      data = json.loads(candidate)\n      MCQList.model_validate(data)\n      return questions  \u2190 EXIT\n    except:\n      continue\n\n  if attempt == 2:\n    raise ValueError\n\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nAttempt 1 \u2192 3 parse strategies\nAttempt 2 \u2192 3 parse strategies\nAttempt 3 \u2192 3 parse strategies\nTotal: up to 9 ways to parse\n       1 way to succeed","fontSize":10,"fontFamily":4,"version":3,"versionNonce":669255755,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"arrow-to-retry","type":"arrow","x1":1340,"y1":560,"x2":1495,"y2":560,"points":[[0,0],[155,0]],"strokeColor":"#e65100","strokeWidth":1.5,"version":3,"versionNonce":1048032741,"isDeleted":false,"fillStyle":"solid","strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"width":155,"height":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-temp-model","type":"rectangle","x":1500,"y":780,"width":340,"height":220,"fillStyle":"solid","fillColor":"#e8f5e9","strokeColor":"#2e7d32","strokeWidth":2,"borderRadius":10,"version":3,"versionNonce":1316144875,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-temp-model-label-text","type":"text","x":1549.1,"y":759,"width":241.79999999999998,"height":21,"text":"Deep Dive: Temperature & Models","fontSize":13,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":15,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":1,"textColor":"#2e7d32"},{"id":"text-temp-model","type":"text","x":1510,"y":820,"width":320,"height":165,"text":"temperature = 0.8\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n0.0  \u2192  Deterministic\n        Same input = same output\n0.3  \u2192  Low variety, high accuracy\n0.8  \u2192  RECOMMENDED: variety +\n        quality balance\n1.0  \u2192  Max randomness, quality risk\n\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nModel Selection:\n\u251c\u2500 Haiku 4.5  \u2192  Default, fast, cheap\n\u251c\u2500 Sonnet 4   \u2192  Better reasoning\n\u2514\u2500 Opus 4     \u2192  Best quality, costly","fontSize":10,"fontFamily":4,"version":3,"versionNonce":473018693,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"box-dedup","type":"rectangle","x":1500,"y":1040,"width":340,"height":220,"fillStyle":"solid","fillColor":"#fce4ec","strokeColor":"#c62828","strokeWidth":2,"borderRadius":10,"version":3,"versionNonce":1039184267,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-dedup-label-text","type":"text","x":1576.4,"y":1019,"width":187.2,"height":21,"text":"Deep Dive: Deduplication","fontSize":13,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":15,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":1,"textColor":"#c62828"},{"id":"text-dedup","type":"text","x":1510,"y":1080,"width":320,"height":165,"text":"How repetition is prevented\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nClick 1: session_state.mcqs = []\n  \u2192 API receives no exclusion list\n  \u2192 Generates 5 questions Q1-Q5\n  \u2192 Displayed + stored in mcqs\n\nClick 2: session_state.mcqs = [Q1-Q5]\n  \u2192 Passed as exclude_questions\n  \u2192 build_user_prompt() appends:\n    \"DO NOT REPEAT: Q1...Q5\"\n  \u2192 Model forced to generate Q6-Q10\n\nClick N: same pattern repeats\n  \u2192 All previous questions excluded\n  \u2192 Exhausts unique topics naturally\n    (no more new questions possible)","fontSize":10,"fontFamily":4,"version":3,"versionNonce":1540702373,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"box-session-flow","type":"rectangle","x":1500,"y":1300,"width":340,"height":220,"fillStyle":"solid","fillColor":"#e3f2fd","strokeColor":"#1565c0","strokeWidth":2,"borderRadius":10,"version":3,"versionNonce":1738033195,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"box-session-flow-label-text","type":"text","x":1576.4,"y":1279,"width":187.2,"height":21,"text":"Deep Dive: Session State","fontSize":13,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":15,"version":1,"versionNonce":123456789,"isDeleted":false,"boundElements":[],"link":null,"locked":false,"opacity":100,"angle":0,"groupIds":[],"roundness":null,"seed":1,"frameId":null,"fontStyle":1,"textColor":"#1565c0"},{"id":"text-session-flow","type":"text","x":1510,"y":1340,"width":320,"height":165,"text":"st.session_state lifecycle\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n_init_state() runs once on import:\n  setdefault for all keys\n\nOn API key change \u2192 st.rerun()\nOn model change   \u2192 clear mcqs\nOn new upload     \u2192 clear mcqs\nOn Generate click \u2192 replace mcqs\n\nWhy not append?\n  SPEC requires: \"Each click\n  replaces (not appends)\"\n\nexclude_questions carries the\nhistory forward \u2014 decoupling\nUI behavior from API behavior.","fontSize":10,"fontFamily":4,"version":3,"versionNonce":856679429,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","baseline":14,"fontStyle":0},{"id":"arrow-main-to-retry","type":"arrow","x1":1340,"y1":560,"x2":1495,"y2":560,"points":[[0,0],[155,0]],"strokeColor":"#e65100","strokeWidth":1.5,"version":3,"versionNonce":827591371,"isDeleted":false,"fillStyle":"solid","strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"width":155,"height":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"title-architecture","type":"text","x":480,"y":0,"width":640,"height":40,"text":"AI LMS \u2014 MCQ Generator: Full Architecture","fontSize":20,"fontFamily":1,"textAlign":"center","version":3,"versionNonce":1172249445,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"verticalAlign":"top","baseline":24,"fontStyle":0},{"id":"subtitle-architecture","type":"text","x":480,"y":34,"width":640,"height":20,"text":"Streamlit + Services Layer + Anthropic Claude API","fontSize":12,"fontFamily":1,"textAlign":"center","version":3,"versionNonce":1606318443,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false,"verticalAlign":"top","baseline":16,"fontStyle":0},{"id":"legend","type":"rectangle","x":0,"y":1090,"width":220,"height":200,"fillStyle":"solid","fillColor":"#fafafa","strokeColor":"#bdbdbd","strokeWidth":1,"borderRadius":8,"version":3,"versionNonce":1552967365,"isDeleted":false,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"locked":false},{"id":"legend-text","type":"text","x":10,"y":1100,"width":200,"height":180,"text":"LEGEND\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n\u2192 Solid arrow\n  Data flow direction\n\n\u21e2 Dashed arrow\n  State dependency\n\nBlue  = Frontend / API\nGreen = Document processing\nOrange= Retry & parse logic\nPurple= External API\nRed   = Pydantic validation","fontSize":10,"fontFamily":1,"version":3,"versionNonce":1075975179,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","seed":1,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"link":null,"