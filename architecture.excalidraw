    },
    {
      "id": "text-retry-flow",
      "type": "text",
      "x": 1510,
      "y": 478,
      "width": 320,
      "height": 250,
      "text": "generate_mcqs()\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\n\nfor attempt in range(3):\n  raw = _call_api(...)\n\n  for strategy in\n  [raw, strip_fences,\n   scan_anywhere]:\n\n    try:\n      data = json.loads(candidate)\n      MCQList.model_validate(data)\n      return questions  в†ђ EXIT\n    except:\n      continue\n\n  if attempt == 2:\n    raise ValueError\n\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nAttempt 1 в†’ 3 parse strategies\nAttempt 2 в†’ 3 parse strategies\nAttempt 3 в†’ 3 parse strategies\nTotal: up to 9 ways to parse\n       1 way to succeed",
      "fontSize": 10,
      "fontFamily": "Courier New",
      "color": "#e65100"
    },
