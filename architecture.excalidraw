    {
      "id": "text-mcq-model",
      "type": "text",
      "x": 295,
      "y": 760,
      "width": 320,
      "height": 100,
      "text": "class MCQ(BaseModel)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў question:     str  min_length=5\nвЂў options:       List[str]  4 items\nвЂў answer:       str  must match\n               one of options\nвЂў explanation:   str  min_length=10\n\nmodel_post_init():\n  raises ValueError if answer в€‰ options",
      "fontSize": 10,
      "fontFamily": "Courier New",
      "color": "#b71c1c"
    },
    {
      "id": "text-mcql-model",
      "type": "text",
      "x": 640,
      "y": 760,
      "width": 320,
      "height": 100,
      "text": "class MCQList(BaseModel)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў questions: List[MCQ]\n              min_length=5\n              max_length=5\n\nIf validation fails:\n  в†’ Exception caught in retry loop\n  в†’ Fresh API call made\n  в†’ Up to 3 total attempts",
      "fontSize": 10,
      "fontFamily": "Courier New",
      "color": "#b71c1c"
    },
    {
      "id": "text-system-prompt",
      "type": "text",
      "x": 990,
      "y": 760,
      "width": 340,
      "height": 100,
      "text": "SYSTEM_PROMPT Rules\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Return ONLY JSON (no fences)\nвЂў Exactly 5 questions\nвЂў 4 distinct options each\nвЂў Different topics вЂ” no overlap\nвЂў Answer = one option verbatim\nвЂў Moderate difficulty\nвЂў If too short в†’ \"limitation\"\nвЂў NOTHING else in response",
      "fontSize": 10,
      "fontFamily": "Courier New",
      "color": "#b71c1c"
    },
    {
      "id": "box-external-api",
      "type": "rectangle",
      "x": 400,
